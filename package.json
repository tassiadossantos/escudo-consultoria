{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "dev": "pnpm run dev:site",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:site": "pnpm --filter @workspace/sst-consultoria exec cross-env PORT=5174 BASE_PATH=/ vite --config vite.config.ts --host 0.0.0.0",
    "dev:preview": "pnpm --filter @workspace/mockup-sandbox exec cross-env PORT=5173 BASE_PATH=/ vite --config vite.config.ts --host 0.0.0.0",
    "dev:all": "pnpm -w --parallel run dev:site dev:preview"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.1",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "@types/jest": "^30.0.0",
    "autocannon": "^8.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "k6": "^0.0.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "vite": "catalog:",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:",
    "class-variance-authority": "catalog:",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "framer-motion": "catalog:",
    "gray-matter": "^4.0.3",
    "lucide-react": "catalog:",
    "pg": "^8.20.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "catalog:",
    "twilio": "^5.13.1",
    "wouter": "^3.9.0",
    "zod": "catalog:"
  }
}
