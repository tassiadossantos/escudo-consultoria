{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "npm run typecheck && pnpm -r --if-present run build",
    "dev": "pnpm run dev:site",
    "typecheck:libs": "pnpm exec tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "type-check": "npm run typecheck",
    "test": "dotenv -e .env -- vitest run",
    "test:unit": "dotenv -e .env -- vitest run --poolOptions.threads.maxThreads=1 --poolOptions.threads.minThreads=1",
    "test:watch": "vitest",
    "test:coverage": "dotenv -e .env -- vitest run --coverage --poolOptions.threads.maxThreads=1 --poolOptions.threads.minThreads=1",
    "test:e2e": "npx playwright test --config=playwright.config.ts",
    "lint": "eslint .",
    "supabase:test": "npx supabase test db",
    "supabase:stop": "npx supabase stop",
    "db:push": "dotenv -e .env -- npx drizzle-kit push",
    "db:studio": "npx drizzle-kit studio",
    "dev:site": "pnpm --filter @workspace/sst-consultoria exec cross-env PORT=5174 BASE_PATH=/ vite --config vite.config.ts --host 0.0.0.0",
    "dev:preview": "pnpm --filter @workspace/mockup-sandbox exec cross-env PORT=5173 BASE_PATH=/ vite --config vite.config.ts --host 0.0.0.0",
    "dev:all": "pnpm -w --parallel run dev:site dev:preview"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@rollup/rollup-win32-x64-msvc": "^4.59.1",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/node": "25.9.2",
    "@types/supertest": "^7.2.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "2.1.9",
    "autocannon": "^8.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.21.0",
    "k6": "^0.0.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.3",
    "vite": "catalog:",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "framer-motion": "catalog:",
    "gray-matter": "^4.0.3",
    "lucide-react": "catalog:",
    "pg": "^8.20.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "catalog:",
    "twilio": "^5.13.1",
    "wouter": "^3.9.0",
    "zod": "catalog:"
  }
}
